# Helix Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# Required -- OpenRouter is the default provider for all roles
GENE_OPENROUTER_API_KEY=your-openrouter-api-key-here

# Alternative provider keys (only needed if you override the default provider)
# GENE_GEMINI_API_KEY=your-gemini-api-key-here
# GENE_OPENAI_API_KEY=your-openai-api-key-here

# Optional -- defaults shown
# GENE_DATABASE_URL=sqlite+aiosqlite:///./helix.db
# CORS_ORIGINS=*
# GENE_META_MODEL=anthropic/claude-sonnet-4
# GENE_TARGET_MODEL=openai/gpt-4o-mini
# GENE_JUDGE_MODEL=anthropic/claude-sonnet-4
# GENE_META_PROVIDER=openrouter
# GENE_TARGET_PROVIDER=openrouter
# GENE_JUDGE_PROVIDER=openrouter

# PostgreSQL (only needed with: docker compose --profile postgres up)
# GENE_DATABASE_URL=postgresql+asyncpg://helix:helix_dev@postgres:5432/helix
# POSTGRES_PASSWORD=helix_dev
